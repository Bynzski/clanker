{
  "name": "clanker-grid",
  "version": "0.1.0",
  "description": "Developer workspace tool with terminal grid and web browser",
  "main": "dist/main/main.js",
  "author": "you",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && cross-env NODE_ENV=development electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.main.json --noEmit",
    "test": "npm run build:main && node --test dist/main/*.test.js",
    "validate": "npm run typecheck && npm run build && npm run test",
    "build:dist": "npm run build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "electron-store": "8.2.0",
    "lucide-react": "^1.7.0",
    "node-pty": "^1.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "4.9.0",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "electron": "41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "6.0.2",
    "vite": "8.0.3"
  },
  "build": {
    "appId": "com.clankergrid.app",
    "productName": "Clanker Grid",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
